{
  "_comment": "Codex Proxy Launcher configuration",
  "_version": 1,
  "log_level": "info",
  "proxy": {
    "type": "http",
    "host": "127.0.0.1",
    "port": 10808
  },
  "bypass_list": [
    "<-loopback>",
    "localhost",
    "127.0.0.1",
    "::1",
    "10.*",
    "172.16.*",
    "172.17.*",
    "172.18.*",
    "172.19.*",
    "172.20.*",
    "172.21.*",
    "172.22.*",
    "172.23.*",
    "172.24.*",
    "172.25.*",
    "172.26.*",
    "172.27.*",
    "172.28.*",
    "172.29.*",
    "172.30.*",
    "172.31.*",
    "192.168.*"
  ],
  "disable_quic": true,
  "set_proxy_environment": false
}
